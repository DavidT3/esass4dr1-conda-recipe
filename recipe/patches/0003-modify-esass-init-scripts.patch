--- eSASS/autoconf/setup/esass-init.sh.in
+++ eSASS/autoconf/setup/esass-init.sh.in
@@ -2,8 +2,9 @@
 # Setup script for eSASS environment
 # This file has been automatically generated at eSASS compile time

-export HEADAS=@HEASOFT@
-source $HEADAS/headas-init.sh
+# Automatic HEADAS setting and HEASoft activation has been patched out of this
+#  Conda-packaged version of eSASS - it will be handled by the HEASoft Conda
+#  package activation scripts.

 export SASS_ROOT=$(realpath $(dirname $BASH_SOURCE)/../)
 export SASS_DIR=$SASS_ROOT
@@ -36,4 +37,19 @@
 #ulimit -s 32768


+# Patched in during Conda package build
+if [ -z "$CALDB" ]; then
+    echo "WARNING: The CALDB environment variable is not set."
+    echo "Please set CALDB to your calibration database path. For example:"
+    echo "  export CALDB=/path/to/caldb4DR1-esass"
+    echo "Once set, you will need to manually configure the following variables:"
+    echo "  export CALDBCONFIG=\$CALDB/software/tools/caldb.config"
+    echo "  export CALDBALIAS=\$CALDB/software/tools/alias_config.fits"
+    echo "  export SASS_CALVERS=\$CALDB/data/erosita/calvers.indx"
+else
+    export CALDBCONFIG=$CALDB/software/tools/caldb.config
+    export CALDBALIAS=$CALDB/software/tools/alias_config.fits
+    export SASS_CALVERS=$CALDB/data/erosita/calvers.indx
+fi
+
 # CALDB



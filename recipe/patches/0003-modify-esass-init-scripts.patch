@@ -38,3 +38,18 @@


 # CALDB
+
+
+if [ -z "$CALDB" ]; then
+    echo "WARNING: The CALDB environment variable is not set."
+    echo "Please set CALDB to your calibration database path. For example:"
+    echo "  export CALDB=/path/to/caldb4DR1-esass"
+    echo "Once set, you will need to manually configure the following variables:"
+    echo "  export CALDBCONFIG=\$CALDB/software/tools/caldb.config"
